      <expressionfields>
        <field length="0" subType="0" type="2" typeName="integer" precision="0" comment="" expression="with_variable('s',lower(left(id,4)),&#xa;if(@s='over',1,&#xa;if(@s='gene',2,&#xa;if(@s='coas',3,&#xa;if(@s='appr',4,&#xa;if(@s='harb',5,&#xa;if(@s='bert',6,&#xa;0)))))))" name="uband"/>
        <field length="0" subType="0" type="2" typeName="integer" precision="0" comment="" expression="if(catcam=1,13, -- north&#xa;if(catcam=2,11, -- east&#xa;if(catcam=3,14, -- south&#xa;if(catcam=4,10, -- west&#xa;if(boyshp and colour='3,1',3, -- safe water&#xa;if(colour='2,3,2',4, -- isolated danger&#xa;if(catlam=2 and objnam='1',1, -- first starboard&#xa;if(catlam=1 and objnam='2',5, -- first port&#xa;if(colour=6 and array_intersect(string_to_array(catspm), array(1,6,27,50)),7,&#xa;TOPSHP)))))))))" name="topshp"/>
        <field length="0" subType="0" type="10" typeName="string" precision="0" comment="" expression="if(beacon_type is not null or buoy_type is not null,&#xa;if(CATCAM is not null,'B',&#xa;if(COLOUR='3,1','R',&#xa;if(COLOUR='2,3,2','B',&#xa;if(COLOUR='6','Y',&#xa;if(COLOUR='4','G',&#xa;if(COLOUR='3','R',&#xa;0)))))),COLOUR)" name="topcol"/>
      </expressionfields>
