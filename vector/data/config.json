{
  "options": {
    "paths": {
      "root": "/data",
      "styles": "styles",
      "sprites": "sprites",
      "fonts": "fonts"
    },
    "serveAllStyles": true,
    "serveAllFonts": true,
    "maxScaleFactor": 2,
    "leafletRetina": false,
    "tileMargin": 128,
    "formatOptions": {
      "png": {
        "palette": true,
        "colors": 256
      }
    }
  },
  "data": {
    "qmap-de": {
      "mbtiles": "qmap-de.mbtiles"
    },
    "qmap-nl": {
      "mbtiles": "qmap-nl.mbtiles"
    }
  }
}
