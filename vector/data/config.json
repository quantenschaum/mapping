{
  "options": {
    "paths": {
      "root": "/data",
      "styles": "styles",
      "sprites": "sprites",
      "fonts": "fonts"
    },
    "serveAllStyles": true,
    "serveAllFonts": true,
    "maxScaleFactor": 2,
    "leafletRetina": false,
    "tileMargin": 256,
    "formatOptions": {
      "png": {
        "palette": true,
        "colors": 256
      }
    }
  },
  "data": {
    "fnc-de": {
      "mbtiles": "fnc-de.mbtiles"
    },
    "fnc-nl": {
      "mbtiles": "fnc-nl.mbtiles"
    }
  }
}
